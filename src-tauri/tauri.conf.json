{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "АйРомашка",
  "version": "0.1.0",
  "identifier": "com.iromashka.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "https://iromashka.ru/app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "АйРомашка",
        "width": 1024,
        "height": 700,
        "resizable": true,
        "url": "https://iromashka.ru/app"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
